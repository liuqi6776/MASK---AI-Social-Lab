# ============================================
# MASK Server Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=development
API_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mask

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI: DeepSeek (Primary LLM)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# AI: OpenAI (Fallback / Image Generation)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
GPT_IMAGE_MODEL=gpt-image-1
GPT_IMAGE_QUALITY=medium

# AI: Google Imagen (Alternative Image)
GOOGLE_API_KEY=your_google_api_key
IMAGEN_MODEL=imagen-4.0-fast-generate-001

# Image Provider Priority: openai | google
IMAGE_PROVIDER=openai

# Vector Database (Pinecone) - AI Character Memory
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=mask-ai-memory
PINECONE_NAMESPACE=default

# Content Moderation
MODERATION_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=your_aliyun_key
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173,https://mask.ai

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Feature Flags
ENABLE_AI_CHAT=true
ENABLE_IMAGE_GENERATION=true
ENABLE_TURING_GAME=true
ENABLE_CONTENT_MODERATION=true
